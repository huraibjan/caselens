# ===================================================================
# CaseIntelix — Environment Configuration
# ===================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ===================================================================

# ── Application ────────────────────────────────────────────────────
APP_NAME=CaseIntelix
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-this-to-a-random-64-char-string

# ── Database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://caselens:caselens_dev_password@localhost:5432/caselens
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth ───────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-different-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# Google Sign-In (optional). Create a Web OAuth client ID at
# https://console.cloud.google.com/apis/credentials and set the SAME value in
# both GOOGLE_CLIENT_ID (API, below) and NEXT_PUBLIC_GOOGLE_CLIENT_ID (web).
GOOGLE_CLIENT_ID=

# ── Storage (S3-Compatible / MinIO) ───────────────────────────────
STORAGE_BACKEND=minio
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=caselens-documents
STORAGE_USE_SSL=false
STORAGE_REGION=us-east-1

# ── Temporal ───────────────────────────────────────────────────────
# Document processing: "inline" runs the pipeline inside the API process (no
# Temporal/worker needed — single free-tier service). "temporal" uses the worker.
DOCUMENT_PROCESSING_MODE=inline
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=caselens
TEMPORAL_TASK_QUEUE=document-processing

# ── AI Gateway ─────────────────────────────────────────────────────
# AI_PROVIDER / AI_EMBEDDING_PROVIDER / AI_RERANKING_PROVIDER below are
# DEPRECATED — superseded by the fallback chains further down. Left in place
# only so old .env files still parse.
AI_PROVIDER=mock
AI_EMBEDDING_PROVIDER=mock
AI_EMBEDDING_DIMENSIONS=384
AI_RERANKING_PROVIDER=mock

# Ordered, comma-separated provider fallback chains. Each provider is
# automatically skipped if its API key below is empty. If every provider is
# unavailable, the request returns an honest "AI unavailable" error (unless
# AI_ALLOW_MOCK_FALLBACK=true — see below).
# Reorder/add/remove providers by editing these lists, no code change needed.
#
# Chat lane (used by the "ask" and "generate-letter" endpoints): fast free
# providers first (Cerebras/Groq answer in ~200ms), then Gemini and the rest.
# OpenAI is deliberately excluded — it's paid. Add it at the end only if you
# want a paid last-resort backstop.
AI_CHAT_PROVIDER_CHAIN=cerebras,groq,gemini,nvidia,openrouter
# Document-analysis lane (used by the Temporal worker's case-intelligence
# extraction): free-tier fast-inference providers, in priority order.
AI_ANALYSIS_PROVIDER_CHAIN=cerebras,groq,nvidia,openrouter
# Embedding lane: only Gemini/OpenAI are wired for embeddings — Groq/Cerebras
# have no embeddings endpoint and OpenRouter's is unreliable at the free tier.
# Gemini only, to stay fully free. Add ",openai" for a paid fallback.
AI_EMBEDDING_PROVIDER_CHAIN=gemini

# When all real providers are unavailable: false (default) returns an honest
# "AI unavailable" error; true serves deterministic Mock placeholder text
# (NOT real analysis). Keep false for anything user-facing; set true only for
# offline/dev/CI where running with zero API keys is intentional.
AI_ALLOW_MOCK_FALLBACK=false

# Fallback-chain tuning (defaults are sane; override only if needed)
AI_PROVIDER_TIMEOUT_SECONDS=30.0
AI_PROVIDER_MAX_RETRIES=2
AI_PROVIDER_COOLDOWN_SECONDS=60
AI_PROVIDER_RATE_LIMIT_COOLDOWN_SECONDS=45
AI_PROVIDER_AUTH_ERROR_COOLDOWN_SECONDS=300

# Provider credentials — get a free API key from each provider's console:
#   Gemini:     https://aistudio.google.com/apikey
#   Nvidia NIM: https://build.nvidia.com  (API Key on any model page)
#   Groq:       https://console.groq.com/keys
#   Cerebras:   https://cloud.cerebras.ai
#   OpenRouter: https://openrouter.ai/keys  (use :free-suffixed models for $0 cost)
OPENAI_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=

# Free-tier-appropriate default models (override per-provider if desired)
GEMINI_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
GROQ_MODEL=llama-3.1-8b-instant
CEREBRAS_MODEL=gpt-oss-120b
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── AI Provider Approval (required before enabling real providers) ─
# AI_PROVIDER_APPROVED_FOR_CONFIDENTIAL=false
# AI_PROVIDER_DATA_RETENTION_REVIEWED=false
# AI_PROVIDER_TRAINING_REVIEWED=false
# AI_PROVIDER_REGIONAL_REQUIREMENTS_REVIEWED=false
# AI_PROVIDER_CONTRACTUAL_TERMS_REVIEWED=false
# AI_PROVIDER_FIRM_AUTHORIZED=false

# ── Document Processing ───────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100
ALLOWED_MIME_TYPES=application/pdf
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# ── Frontend ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=CaseIntelix
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# ── Rate Limiting ──────────────────────────────────────────────────
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=100
